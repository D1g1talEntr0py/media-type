{
	"name": "@d1g1tal/media-type",
	"author": "D1g1talEntr0py",
	"version": "6.0.7",
	"license": "MIT",
	"description": "Parses, serializes, and manipulates media types, according to the WHATWG MIME Sniffing Standard",
	"homepage": "https://github.com/D1g1talEntr0py/media-type#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/D1g1talEntr0py/media-type.git"
	},
	"bugs": {
		"url": "https://github.com/D1g1talEntr0py/media-type/issues"
	},
	"maintainers": [
		{
			"name": "D1g1talEntr0py",
			"email": "jason.dimeo@gmail.com"
		}
	],
	"engines": {
		"node": ">=20.16.0"
	},
	"packageManager": "pnpm@10.32.1",
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"access": "public"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/media-type.d.ts",
			"import": "./dist/media-type.js"
		}
	},
	"files": [
		"/dist",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsbuild",
		"build:watch": "tsbuild --watch",
		"type-check": "tsbuild --noEmit",
		"lint": "eslint ./src",
		"pretest": "node tests/scripts/get-latest-platform-tests.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest run --ui",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@d1g1tal/tsbuild": "^1.7.5",
		"@eslint/js": "^10.0.1",
		"@exodus/bytes": "^1.15.0",
		"@types/node": "^25.5.2",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"@typescript-eslint/parser": "^8.58.0",
		"@typescript/lib-dom": "npm:@types/web@^0.0.345",
		"@vitest/coverage-v8": "4.1.3",
		"@vitest/ui": "^4.1.3",
		"eslint": "^10.2.0",
		"eslint-plugin-jsdoc": "^62.9.0",
		"printable-string": "^0.3.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.3"
	},
	"browserslist": [
		"defaults and fully supports es6-module",
		"maintained node versions"
	],
	"keywords": [
		"content-type",
		"mime type",
		"media type",
		"mimesniff",
		"mime",
		"http",
		"whatwg",
		"typescript",
		"esm",
		"parser",
		"serializer"
	]
}
