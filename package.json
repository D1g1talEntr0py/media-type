{
	"name": "@d1g1tal/media-type",
	"description": "Parses, serializes, and manipulates media types, according to the WHATWG MIME Sniffing Standard",
	"version": "6.0.0",
	"author": "Domenic Denicola <d@domenic.me> (https://domenic.me/)",
	"maintainers": [
		{
			"name": "Jason DiMeo",
			"email": "jason.dimeo@gmail.com"
		}
	],
	"license": "ISC",
	"packageManager": "pnpm@10.30.3",
	"engines": {
		"node": ">=20.16.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/D1g1talEntr0py/media-type.git"
	},
	"bugs": {
		"url": "https://github.com/D1g1talEntr0py/media-type/issues"
	},
	"homepage": "https://github.com/D1g1talEntr0py/media-type#readme",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/media-type.d.ts",
			"import": "./dist/media-type.js"
		}
	},
	"files": [
		"/dist",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"keywords": [
		"content-type",
		"mime type",
		"media type",
		"mimesniff",
		"mime",
		"http",
		"whatwg",
		"typescript",
		"esm",
		"parser",
		"serializer"
	],
	"scripts": {
		"build": "tsbuild",
		"type-check": "tsbuild --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest run --ui",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint",
		"pretest": "node tests/scripts/get-latest-platform-tests.ts"
	},
	"devDependencies": {
		"@d1g1tal/tsbuild": "^1.3.0",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.3.3",
		"@typescript-eslint/eslint-plugin": "^8.56.1",
		"@typescript-eslint/parser": "^8.56.1",
		"@typescript/lib-dom": "npm:@types/web@^0.0.338",
		"@vitest/coverage-v8": "4.0.18",
		"@vitest/ui": "^4.0.18",
		"eslint": "^10.0.2",
		"eslint-plugin-jsdoc": "^62.7.1",
		"printable-string": "^0.3.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vitest": "^4.0.18",
		"whatwg-encoding": "^3.1.1"
	},
	"browserslist": [
		"defaults and fully supports es6-module",
		"maintained node versions"
	]
}
